    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "@types/sortablejs": "^1.15.8",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.3.0"
